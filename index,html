<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Indonesia Real Estate & Construction Services</title>
    <!-- SEO Meta Tags -->
    <meta name="description" content="Professional real estate, construction, and interior design services in Indonesia.">
    <meta name="keywords" content="Real Estate Indonesia, Property Construction, Interior Design, Jual Beli Properti, العقارات في إندونيسيا">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .hero-bg {
            background: linear-gradient(rgba(30, 58, 138, 0.8), rgba(30, 58, 138, 0.8)), 
                        url('https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
        }
        [dir="rtl"] { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 transition-all duration-300">

    <!-- NAVIGATION -->
    <nav class="bg-blue-900 text-white p-4 shadow-lg sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <img src="https://placehold.co/50x50/white/blue?text=Logo" alt="Logo" class="h-10 w-10 rounded-full">
                <h1 class="text-xl font-bold" data-i18n="title">Indonesia Real Estate</h1>
            </div>
            <div class="flex items-center space-x-4">
                <select id="langSwitcher" class="bg-blue-800 p-1 rounded text-sm border-none focus:ring-0 cursor-pointer">
                    <option value="en">English</option>
                    <option value="id">Bahasa Indonesia</option>
                    <option value="ar">العربية</option>
                </select>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <header class="hero-bg text-white py-24 px-6 text-center">
        <div class="container mx-auto max-w-4xl">
            <h2 class="text-4xl md:text-6xl font-bold mb-6" data-i18n="hero_title">Building Your Real Estate Future</h2>
            <p class="text-xl mb-8" data-i18n="hero_desc">Professional expertise combined with luxury, innovation, and craftsmanship.</p>
        </div>
    </header>

    <!-- SERVICES SECTION -->
    <section id="services" class="py-16 container mx-auto px-6">
        <h3 class="text-3xl font-bold text-center mb-12 text-blue-900" data-i18n="services_title">Our Services</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="servicesGrid">
            <!-- سيتم تعبئة الخدمات برمجياً -->
        </div>
    </section>

    <!-- FOOTER SECTION -->
    <footer class="bg-blue-900 text-white py-12 mt-10">
        <div class="container mx-auto px-6 text-center">
            <h4 class="text-xl font-bold mb-6" data-i18n="connect">Connect With Us</h4>
            <div class="flex justify-center space-x-8 text-3xl">
                <!-- استبدل الروابط أدناه بروابط حساباتك الحقيقية -->
                <a href="https://wa.me/YOUR_WHATSAPP_NUMBER" target="_blank" class="hover:text-green-400 transition"><i class="fab fa-whatsapp"></i></a>
                <a href="https://tiktok.com/@YOUR_TIKTOK_USER" target="_blank" class="hover:text-pink-400 transition"><i class="fab fa-tiktok"></i></a>
                <a href="https://facebook.com/YOUR_FACEBOOK_PAGE" target="_blank" class="hover:text-blue-400 transition"><i class="fab fa-facebook"></i></a>
                <a href="https://instagram.com/YOUR_INSTAGRAM_USER" target="_blank" class="hover:text-purple-400 transition"><i class="fab fa-instagram"></i></a>
            </div>
            <p class="mt-8 text-blue-300 text-sm">© 2026 Indonesia Real Estate Services. All rights reserved.</p>
        </div>
    </footer>

    <!-- WHATSAPP FLOATING BUTTON -->
    <a href="https://wa.me/YOUR_WHATSAPP_NUMBER" target="_blank" class="fixed bottom-8 right-8 bg-green-500 text-white p-4 rounded-full shadow-2xl hover:scale-110 transition z-50">
        <i class="fab fa-whatsapp text-3xl"></i>
    </a>

    <script>
        const services = [
            { id: "serv1", title: { en: "Buying & Selling", id: "Jual Beli Properti", ar: "بيع وشراء العقارات" }, desc: { en: "Best market opportunities.", id: "Peluang pasar terbaik.", ar: "أفضل الفرص في السوق." }, imgs: ["https://placehold.co/200x150/cbd5e1/5e5e5e?text=Img1", "https://placehold.co/200x150/94a3b8/5e5e5e?text=Img2", "https://placehold.co/200x150/64748b/5e5e5e?text=Img3"] },
            { id: "serv2", title: { en: "Property Rental", id: "Penyewaan Properti", ar: "تأجير العقارات" }, desc: { en: "Residential & Commercial.", id: "Hunian & Komersial.", ar: "سكنية وتجارية." }, imgs: ["https://placehold.co/200x150/cbd5e1/5e5e5e?text=Img1", "https://placehold.co/200x150/94a3b8/5e5e5e?text=Img2", "https://placehold.co/200x150/64748b/5e5e5e?text=Img3"] },
            { id: "serv3", title: { en: "Modern Engineering", id: "Desain Teknik", ar: "تصاميم هندسية" }, desc: { en: "Luxury & Innovation.", id: "Kemewahan & Inovasi.", ar: "فخامة وابتكار." }, imgs: ["https://placehold.co/200x150/cbd5e1/5e5e5e?text=Img1", "https://placehold.co/200x150/94a3b8/5e5e5e?text=Img2", "https://placehold.co/200x150/64748b/5e5e5e?text=Img3"] },
            { id: "serv4", title: { en: "Interior & Exterior", id: "Desain Interior & Eksterior", ar: "ديكورات داخلية وخارجية" }, desc: { en: "World-class designs.", id: "Desain kelas dunia.", ar: "بأحدث التصاميم العالمية." }, imgs: ["https://placehold.co/200x150/cbd5e1/5e5e5e?text=Img1", "https://placehold.co/200x150/94a3b8/5e5e5e?text=Img2", "https://placehold.co/200x150/64748b/5e5e5e?text=Img3"] },
            { id: "serv5", title: { en: "Construction Project", id: "Proyek Konstruksi", ar: "تنفيذ مشاريع البناء" }, desc: { en: "Professional quality.", id: "Kualitas profesional.", ar: "جودة احترافية عالية." }, imgs: ["https://placehold.co/200x150/cbd5e1/5e5e5e?text=Img1", "https://placehold.co/200x150/94a3b8/5e5e5e?text=Img2", "https://placehold.co/200x150/64748b/5e5e5e?text=Img3"] },
            { id: "serv6", title: { en: "Real Estate Consult", id: "Konsultasi Properti", ar: "استشارات عقارية" }, desc: { en: "Expert decision advice.", id: "Saran keputusan ahli.", ar: "مساعدتكم في أفضل القرارات." }, imgs: ["https://placehold.co/200x150/cbd5e1/5e5e5e?text=Img1", "https://placehold.co/200x150/94a3b8/5e5e5e?text=Img2", "https://placehold.co/200x150/64748b/5e5e5e?text=Img3"] }
        ];

        const translations = {
            en: { title: "Indonesia Real Estate", hero_title: "Building Your Real Estate Future", hero_desc: "Professional expertise combined with luxury, innovation, and craftsmanship.", services_title: "Our Services", connect: "Connect With Us" },
            id: { title: "Properti Indonesia", hero_title: "Membangun Masa Depan Properti Anda", hero_desc: "Keahlian profesional dipadukan dengan kemewahan, inovasi, dan kualitas pengerjaan.", services_title: "Layanan Kami", connect: "Hubungi Kami" },
            ar: { title: "عقارات إندونيسيا", hero_title: "نصنع مستقبلك العقاري", hero_desc: "خبرة تجمع بين الفخامة، الابتكار، والاحترافية في التنفيذ.", services_title: "خدماتنا", connect: "تواصل معنا" }
        };

        function renderServices(lang) {
            const grid = document.getElementById('servicesGrid');
            grid.innerHTML = services.map(s => `
                <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition border-b-4 border-blue-600 flex flex-col">
                    <div class="p-6 flex-grow">
                        <h4 class="text-xl font-bold mb-2">${s.title[lang]}</h4>
                        <p class="text-gray-600 text-sm">${s.desc[lang]}</p>
                    </div>
                    <div class="flex gap-1 p-2 bg-gray-50 border-t">
                        ${s.imgs.map(img => `<img src="${img}" class="w-1/3 h-20 object-cover rounded shadow-sm">`).join('')}
                    </div>
                </div>
            `).join('');
        }

        document.getElementById('langSwitcher').addEventListener('change', (e) => {
            const lang = e.target.value;
            document.documentElement.lang = lang;
            document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                el.textContent = translations[lang][key];
            });
            renderServices(lang);
        });

        renderServices('en');
    </script>
</body>
</html>
